<?xml version="1.0" encoding="UTF-8"?>
<fault-injection>

    <model>RR_Protocol.smv</model>

    <protocol-type>RR</protocol-type>

    <modules>

        <module name="Client">

            <redundancy count="3"/>

            <faults>
                <fault id="stuck_sending">
                    <type>stuck-at</type>
                    <variable>client_request_state</variable>
                    <value>sending</value>
                </fault>

                <fault id="stuck_sent">
                    <type>stuck-at</type>
                    <variable>client_request_state</variable>
                    <value>sent</value>
                </fault>
            </faults>

        </module>

        <module name="Server">

            <redundancy count="2"/>

            <faults>
                <fault id="stuck_receiving">
                    <type>stuck-at</type>
                    <variable>server_request_state</variable>
                    <value>receiving</value>
                </fault>

                <fault id="stuck_received">
                    <type>stuck-at</type>
                    <variable>server_request_state</variable>
                    <value>received</value>
                </fault>
            </faults>

        </module>

    </modules>

    <properties>
        <property id="nominal_implies_extended">
            <comment></comment>
            <spec>
                nominal.client.num_requests_sent =
                extended.client1.num_requests_sent +
                extended.client2.num_requests_sent +
                extended.client3.num_requests_sent
            </spec>
        </property>
    </properties>

</fault-injection>