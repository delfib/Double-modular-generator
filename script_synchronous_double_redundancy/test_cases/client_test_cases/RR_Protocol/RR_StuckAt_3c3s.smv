MODULE Queue(Q_SIZE, producer_toggle, consumer_toggle)
VAR
    head : 0..3;
    tail : 0..3;
    last_producer_toggle : boolean;  -- last toggle value we saw
    last_consumer_toggle : boolean;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
    init(last_producer_toggle) := FALSE;
    init(last_consumer_toggle) := FALSE;

    next(tail) := case
        (producer_toggle != last_producer_toggle) : (tail + 1) mod Q_SIZE;    -- produce if toggle changed (new request detected)
        TRUE : tail;
    esac;

    next(head) := case
        (consumer_toggle != last_consumer_toggle) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

    next(last_producer_toggle) := case
        (producer_toggle != last_producer_toggle) : producer_toggle;
        TRUE : last_producer_toggle;
    esac;

    next(last_consumer_toggle) := case
        (consumer_toggle != last_consumer_toggle) : consumer_toggle;
        TRUE : last_consumer_toggle;
    esac;

DEFINE
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);



MODULE Client(request_queue, ack_queue)
VAR
    client_request_state : {sending, sent};
    client_ack_state  : {receiving, received};
    request_toggle : boolean;  
    ack_toggle : boolean;    
    ack_received : boolean;
    num_requests_sent : 0..100;    

ASSIGN
    init(client_request_state) := sending;
    init(client_ack_state)  := receiving;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(ack_received) := TRUE;
    init(num_requests_sent) := 0;

    next(client_request_state) := case
            client_request_state = sending & request_queue.full : sending;
            client_request_state = sending & !request_queue.full & ack_received : sent;
            client_request_state = sent & !request_queue.full : sending;
            client_request_state = sent & request_queue.full : sent;
            TRUE : client_request_state;
        esac;

    next(client_ack_state) := case
            client_ack_state = receiving & ack_queue.empty : receiving;
            client_ack_state = receiving & !ack_queue.empty : received;
            client_ack_state = received & !ack_queue.empty : receiving;
            client_ack_state = received & ack_queue.empty : received;
            TRUE : client_ack_state;
        esac;

    next(request_toggle) := case
        client_request_state = sending & !request_queue.full & ack_received : !request_toggle;              
        TRUE : request_toggle;                                                      
    esac;

    next(ack_toggle) := case
        client_ack_state = receiving & !ack_queue.empty : !ack_toggle;                   
        TRUE : ack_toggle;                                                      
    esac;

    next(ack_received) := case
        client_request_state = sending & !request_queue.full & ack_received : FALSE;       -- false because a new request has just been sent
        client_ack_state = receiving & !ack_queue.empty : TRUE;          -- true because a new ack has been received
        TRUE : ack_received;           
    esac;

    next(num_requests_sent) := case
        client_request_state = sending & !request_queue.full & ack_received & num_requests_sent < 100 : num_requests_sent + 1;                   
        TRUE : num_requests_sent;                                                    
    esac;



MODULE Server(request_queue, ack_queue)
VAR
    server_request_state : {receiving, received};
    server_ack_state : {sending, sent};
    request_toggle : boolean;  
    ack_toggle : boolean;
    request_received : boolean;
    num_requests_received : 0..100;

ASSIGN
    init(server_request_state) := receiving;
    init(server_ack_state) := sending;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(request_received) := FALSE;
    init(num_requests_received) := 0;

    next(server_request_state) :=
        case
            server_request_state = receiving & request_queue.empty : receiving;
            server_request_state = receiving & !request_queue.empty : received;
            server_request_state = received & !request_queue.empty : receiving;
            server_request_state = received & request_queue.empty : received;
            TRUE : server_request_state;
        esac;

    next(server_ack_state) :=
        case
            server_ack_state = sending & ack_queue.full : sending;
            server_ack_state = sending & !ack_queue.full & request_received : sent;
            server_ack_state = sent & !ack_queue.full : sending;
            server_ack_state = sent & ack_queue.full : sent;
            TRUE : server_ack_state;
        esac;

    next(request_toggle) := case
        server_request_state = receiving & !request_queue.empty : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(ack_toggle) := case
        server_ack_state = sending & !ack_queue.full & request_received : !ack_toggle;                   
        TRUE : ack_toggle;                                                    
    esac;

    next(request_received) := case
        server_ack_state = sending & !ack_queue.full & request_received : FALSE;        -- false because a new ack has just been sent
        server_request_state = receiving & !request_queue.empty : TRUE;         -- true because a new request has been received
        TRUE : request_received;     
    esac;

    next(num_requests_received) := case
        server_request_state = receiving & !request_queue.empty & num_requests_received < 100 : num_requests_received + 1;                   
        TRUE : num_requests_received;                                                    
    esac;
    

MODULE Nominal()
DEFINE
    Q_SIZE := 4;
VAR
    client : Client(request_queue, ack_queue);
    server : Server(request_queue, ack_queue);
    request_queue : Queue(Q_SIZE, client.request_toggle, server.request_toggle);
    ack_queue : Queue(Q_SIZE, server.ack_toggle, client.ack_toggle);


-- =========================================================
-- Queue Extended
-- =========================================================
MODULE QueueExtended(Q_SIZE, producer_toggles, consumer_toggles)
VAR
    producer_id : array 0..3 of {none, clt0, clt1, clt2};
    head : 0..3;
    tail : 0..3;
    last_producer_toggle : array 0..2 of boolean;
    last_consumer_toggle : array 0..2 of boolean;
    next_client_turn : 0..2;
    next_server_turn : 0..2;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
    init(producer_id[0]) := none;
    init(producer_id[1]) := none;
    init(producer_id[2]) := none;
    init(producer_id[3]) := none;
    init(last_producer_toggle[0]) := FALSE;
    init(last_producer_toggle[1]) := FALSE;
    init(last_producer_toggle[2]) := FALSE;
    init(last_consumer_toggle[0]) := FALSE;
    init(last_consumer_toggle[1]) := FALSE;
    init(last_consumer_toggle[2]) := FALSE;
    init(next_client_turn) := {0,1,2};
    init(next_server_turn) := {0,1,2};

    next(tail) := case
        (producer_toggles[0] != last_producer_toggle[0]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[1] != last_producer_toggle[1]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[2] != last_producer_toggle[2]) : (tail + 1) mod Q_SIZE;
        TRUE : tail;
    esac;

    next(producer_id[0]) := case
        tail = 0 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 0 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 0 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        TRUE : producer_id[0];
    esac;

    next(producer_id[1]) := case
        tail = 1 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 1 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 1 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        TRUE : producer_id[1];
    esac;

    next(producer_id[2]) := case
        tail = 2 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 2 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 2 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        TRUE : producer_id[2];
    esac;

    next(producer_id[3]) := case
        tail = 3 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 3 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 3 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        TRUE : producer_id[3];
    esac;

    next(head) := case
        (consumer_toggles[0] != last_consumer_toggle[0]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[1] != last_consumer_toggle[1]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[2] != last_consumer_toggle[2]) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

    next(last_producer_toggle[0]) := case
        (producer_toggles[0] != last_producer_toggle[0]) : producer_toggles[0];
        TRUE : last_producer_toggle[0];
    esac;

    next(last_producer_toggle[1]) := case
        (producer_toggles[1] != last_producer_toggle[1]) : producer_toggles[1];
        TRUE : last_producer_toggle[1];
    esac;

    next(last_producer_toggle[2]) := case
        (producer_toggles[2] != last_producer_toggle[2]) : producer_toggles[2];
        TRUE : last_producer_toggle[2];
    esac;

    next(last_consumer_toggle[0]) := case
        (consumer_toggles[0] != last_consumer_toggle[0]) : consumer_toggles[0];
        TRUE : last_consumer_toggle[0];
    esac;

    next(last_consumer_toggle[1]) := case
        (consumer_toggles[1] != last_consumer_toggle[1]) : consumer_toggles[1];
        TRUE : last_consumer_toggle[1];
    esac;

    next(last_consumer_toggle[2]) := case
        (consumer_toggles[2] != last_consumer_toggle[2]) : consumer_toggles[2];
        TRUE : last_consumer_toggle[2];
    esac;

    next(next_client_turn) := {0,1,2};
    next(next_server_turn) := {0,1,2};

DEFINE
    request_consumed := last_consumer_toggle[0] != consumer_toggles[0] | last_consumer_toggle[1] != consumer_toggles[1] | last_consumer_toggle[2] != consumer_toggles[2];
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);


-- =========================================================
-- Client Extended
-- =========================================================
MODULE ClientExtended(request_queue, ack_queue, ack_owners, client_id, client_states)
VAR
    fault_mode : {none, stuck_sending, stuck_sent};
    client_request_state : {sending, sent};
    client_ack_state  : {receiving, received};
    request_toggle : boolean;
    ack_toggle : boolean;
    ack_received : boolean;
    request_sent : boolean;
    num_requests_sent : 0..100;

ASSIGN
    init(fault_mode) := none;
    init(client_request_state) := sending;
    init(client_ack_state)  := receiving;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(ack_received) := TRUE;
    init(request_sent) := FALSE;
    init(num_requests_sent) := 0;

    next(fault_mode) :=
        case
            fault_mode = none : {none, stuck_sending, stuck_sent};
            TRUE              : fault_mode;
        esac;

    next(client_request_state) := case
        fault_mode = stuck_sending : sending;
        fault_mode = stuck_sent : sent;

            client_request_state = sending & request_queue.full : sending;
            client_request_state = sending & !request_queue.full & ack_received & request_queue.next_client_turn = client_id &
            (client_states[0] = TRUE & client_states[1] = TRUE & client_states[2] = TRUE) : sent;
            client_request_state = sent & !request_queue.full : sending;
            client_request_state = sent & request_queue.full : sent;
            TRUE : client_request_state;
        esac;

    next(client_ack_state) := case
            client_ack_state = receiving & ack_queue.empty : receiving;
            client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id |
            ack_owners[2] = self_id) : received;
            client_ack_state = received & !ack_queue.empty : receiving;
            client_ack_state = received & ack_queue.empty : received;
            TRUE : client_ack_state;
    esac;

    next(request_toggle) := case
        fault_mode = none &
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_client_turn = client_id &
            (client_states[0] = TRUE & client_states[1] = TRUE & client_states[2] = TRUE) : !request_toggle;
        TRUE : request_toggle;
    esac;

    next(ack_toggle) := case
        fault_mode = none &
        client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id |
            ack_owners[2] = self_id) : !ack_toggle;
        TRUE : ack_toggle;
    esac;

    next(ack_received) := case
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_client_turn = client_id &
            (client_states[0] = TRUE & client_states[1] = TRUE & client_states[2] = TRUE) : FALSE;
        client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id |
            ack_owners[2] = self_id) : TRUE;
        TRUE : ack_received;
    esac;

    next(request_sent) := case
        fault_mode = none &
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_client_turn = client_id &
            (client_states[0] = TRUE & client_states[1] = TRUE & client_states[2] = TRUE) : TRUE;
        client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id |
           ack_owners[2] = self_id) : FALSE;
        TRUE : request_sent;
    esac;

    next(num_requests_sent) := case
        fault_mode = none &
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_client_turn = client_id &
            (client_states[0] = TRUE & client_states[1] = TRUE & client_states[2] = TRUE) & num_requests_sent < 100 : num_requests_sent + 1;
        TRUE : num_requests_sent;
    esac;

DEFINE
    self_id := case
        client_id = 0 : clt0;
        client_id = 1 : clt1;
        client_id = 2 : clt2;
    esac;


-- =========================================================
-- Server Extended
-- =========================================================
MODULE ServerExtended(request_queue, ack_queue, server_id)
VAR
    fault_mode : {none, stuck_receiving, stuck_received};
    server_request_state : {receiving, received};
    server_ack_state : {sending, sent};
    request_toggle : boolean;
    ack_toggle : boolean;
    request_received : boolean;
    request_source : {none, clt0, clt1, clt2};
    pending_ack : boolean;
    ack_consume_marker : boolean;
    num_requests_received : 0..100;

ASSIGN
    init(fault_mode) := none;
    init(server_request_state) := receiving;
    init(server_ack_state) := sending;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(request_received) := FALSE;
    init(request_source) := none;
    init(pending_ack) := FALSE;
    init(ack_consume_marker) := FALSE;
    init(num_requests_received) := 0;

    next(fault_mode) := case
        fault_mode = none : {none, stuck_receiving, stuck_received};
        TRUE              : fault_mode;
    esac;

    next(server_request_state) := case
        fault_mode = stuck_receiving : receiving;
        fault_mode = stuck_received : received;

            server_request_state = receiving & request_queue.empty : receiving;
            server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_server_turn = server_id : received;
            server_request_state = received & !request_queue.empty : receiving;
            server_request_state = received & request_queue.empty : received;
            TRUE : server_request_state;
    esac;

    next(server_ack_state) := case
            server_ack_state = sending & ack_queue.full : sending;
            server_ack_state = sending & !ack_queue.full & request_received : sent;
            server_ack_state = sent & !ack_queue.full : sending;
            server_ack_state = sent & ack_queue.full : sent;
            TRUE : server_ack_state;
    esac;

    next(request_toggle) := case
        fault_mode = none &
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_server_turn = server_id : !request_toggle;
        TRUE : request_toggle;
    esac;

    next(ack_toggle) := case
        server_ack_state = sending & !ack_queue.full & request_received : !ack_toggle;
        TRUE : ack_toggle;
    esac;

    next(request_received) := case
        server_ack_state = sending & !ack_queue.full & request_received : FALSE;
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_server_turn = server_id : TRUE;
        TRUE : request_received;
    esac;

    next(request_source) := case
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_server_turn = server_id : request_queue.producer_id[request_queue.head];
        TRUE : request_source;
    esac;

    next(pending_ack) := case
        server_ack_state = sending & !ack_queue.full & request_received : TRUE;
        pending_ack & (
            (request_source = clt0 & ack_queue.last_consumer_toggle[0] != ack_consume_marker) |
            (request_source = clt1 & ack_queue.last_consumer_toggle[1] != ack_consume_marker) |
            (request_source = clt2 & ack_queue.last_consumer_toggle[2] != ack_consume_marker)
        ) : FALSE;
        TRUE : pending_ack;
    esac;

    next(ack_consume_marker) := case
        server_ack_state = sending & !ack_queue.full & request_received & request_source = clt0 : ack_queue.last_consumer_toggle[0];
        server_ack_state = sending & !ack_queue.full & request_received & request_source = clt1 : ack_queue.last_consumer_toggle[1];
        server_ack_state = sending & !ack_queue.full & request_received & request_source = clt2 : ack_queue.last_consumer_toggle[2];
        TRUE : ack_consume_marker;
    esac;

    next(num_requests_received) := case
        fault_mode = none &
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_server_turn = server_id & num_requests_received < 100 : num_requests_received + 1;
        TRUE : num_requests_received;
    esac;


-- =========================================================
-- Extended Wrapper
-- =========================================================
MODULE Extended()
DEFINE
    Q_SIZE := 4;
VAR
    request_prod_toggles : array 0..2 of boolean;
    request_cons_toggles : array 0..2 of boolean;
    ack_prod_toggles : array 0..2 of boolean;
    ack_cons_toggles : array 0..2 of boolean;

    client_states : array 0..2 of boolean;
    ack_owners : array 0..2 of {none, clt0, clt1, clt2};
    client1 : ClientExtended(request_queue, ack_queue, ack_owners, 0, client_states);
    client2 : ClientExtended(request_queue, ack_queue, ack_owners, 1, client_states);
    client3 : ClientExtended(request_queue, ack_queue, ack_owners, 2, client_states);

    server1 : ServerExtended(request_queue, ack_queue, 0);
    server2 : ServerExtended(request_queue, ack_queue, 1);
    server3 : ServerExtended(request_queue, ack_queue, 2);

    request_queue : QueueExtended(Q_SIZE, request_prod_toggles, request_cons_toggles);
    ack_queue : QueueExtended(Q_SIZE, ack_prod_toggles, ack_cons_toggles);

ASSIGN
    request_prod_toggles[0] := client1.request_toggle;
    request_prod_toggles[1] := client2.request_toggle;
    request_prod_toggles[2] := client3.request_toggle;
    request_cons_toggles[0] := server1.request_toggle;
    request_cons_toggles[1] := server2.request_toggle;
    request_cons_toggles[2] := server3.request_toggle;
    ack_prod_toggles[0] := server1.ack_toggle;
    ack_prod_toggles[1] := server2.ack_toggle;
    ack_prod_toggles[2] := server3.ack_toggle;
    ack_cons_toggles[0] := client1.ack_toggle;
    ack_cons_toggles[1] := client2.ack_toggle;
    ack_cons_toggles[2] := client3.ack_toggle;
    client_states[0] := client1.ack_received;
    client_states[1] := client2.ack_received;
    client_states[2] := client3.ack_received;
    ack_owners[0] := server1.request_source;
    ack_owners[1] := server2.request_source;
    ack_owners[2] := server3.request_source;



-- =========================================================
--  Synchronization Module
-- =========================================================
MODULE Sync()
VAR
    nominal  : Nominal();
    extended : Extended();


LTLSPEC (
    -- Force next_client_turn to be initiated as 1
    (extended.request_queue.next_client_turn = 1) &

    -- Force client1 to stay healthy for steps 1
    (extended.client1.fault_mode = none) &

    -- Force client2 to stay healthy for steps 1-7
    (extended.client2.fault_mode = none & X extended.client2.fault_mode = none & 
     X X extended.client2.fault_mode = none & X X X extended.client2.fault_mode = none
     & X X X X extended.client2.fault_mode = none & X X X X X extended.client2.fault_mode = none
     & X X X X X X extended.client2.fault_mode = none)
) ->
    G(nominal.client.num_requests_sent =
    extended.client1.num_requests_sent +
    extended.client2.num_requests_sent)



-- =========================================================
--  Main Module
-- =========================================================
MODULE main
VAR
    sync : Sync();