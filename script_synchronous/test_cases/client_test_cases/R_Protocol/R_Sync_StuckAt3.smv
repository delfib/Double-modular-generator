-- =========================================================
-- Queue module
-- =========================================================
MODULE Queue(Q_SIZE, client_toggle, server_toggle)
VAR
    head : 0..3;
    tail : 0..3;
    last_client_toggle : boolean;  -- last toggle value we saw
    last_server_toggle : boolean;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
    init(last_client_toggle) := FALSE;
    init(last_server_toggle) := FALSE;

    next(tail) := case
        (client_toggle != last_client_toggle) : (tail + 1) mod Q_SIZE;    -- produce if toggle changed (new request detected)
        TRUE : tail;
    esac;

    next(head) := case
        (server_toggle != last_server_toggle) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

    next(last_client_toggle) := case
        (client_toggle != last_client_toggle) : client_toggle;
        TRUE : last_client_toggle;
    esac;

    next(last_server_toggle) := case
        (server_toggle != last_server_toggle) : server_toggle;
        TRUE : last_server_toggle;
    esac;

DEFINE
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);



-- =========================================================
-- Client module
-- =========================================================
MODULE Client(queue)
VAR
    client_state : {sending, sent};
    request_toggle : boolean;  
    requests_sent : 0..100;         

ASSIGN
    init(client_state) := sending;
    init(request_toggle) := FALSE;
    init(requests_sent) := 0;

    next(client_state) :=
        case
            client_state = sending & queue.full : sending;
            client_state = sending & !queue.full : sent;
            client_state = sent & !queue.full & request_toggle = queue.last_client_toggle : sending;
            client_state = sent & queue.full : sent;
            TRUE : client_state;
        esac;
 
    next(request_toggle) := case
        client_state = sending & !queue.full : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(requests_sent) := case
        client_state = sending & !queue.full & requests_sent < 100 : requests_sent + 1;                   
        TRUE : requests_sent;                                                    
    esac;


-- =========================================================
-- Server module
-- =========================================================
MODULE Server(queue)
VAR
    server_state : {receiving, received};
    request_toggle : boolean;  
    requests_received : 0..100;
ASSIGN
    init(server_state) := receiving;
    init(request_toggle) := FALSE;
    init(requests_received) := 0;

    next(server_state) :=
        case
            server_state = receiving & queue.empty : receiving;
            server_state = receiving & !queue.empty : received;
            server_state = received & !queue.empty & request_toggle = queue.last_server_toggle: receiving;
            server_state = received & queue.empty : received;
            TRUE : server_state;
        esac;

    next(request_toggle) := case
        server_state = receiving & !queue.empty : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(requests_received) := case
        server_state = receiving & !queue.empty & requests_received < 100 : requests_received + 1;                   
        TRUE : requests_received;                                                    
    esac;


-- =========================================================
-- Nominal wrapper
-- =========================================================
MODULE NominalR()
DEFINE
    Q_SIZE := 4;
VAR
    client : Client(queue);
    server : Server(queue);
    queue : Queue(Q_SIZE, client.request_toggle, server.request_toggle);



MODULE QueueExtended(Q_SIZE, client_toggles, server_toggle)
VAR
    head : 0..3;
    tail : 0..3;
    last_client_toggle : array 0..2 of boolean;  -- last toggle value we saw
    last_server_toggle : boolean;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
        init(last_client_toggle[0]) := FALSE;
    init(last_client_toggle[1]) := FALSE;
    init(last_client_toggle[2]) := FALSE;
    init(last_server_toggle) := FALSE;

    next(tail) := case
        (client_toggles[0] != last_client_toggle[0]) : (tail + 1) mod Q_SIZE;
        (client_toggles[1] != last_client_toggle[1]) : (tail + 1) mod Q_SIZE;
        (client_toggles[2] != last_client_toggle[2]) : (tail + 1) mod Q_SIZE;
        TRUE : tail;
    esac;

    next(head) := case
        (server_toggle != last_server_toggle) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

        next(last_client_toggle[0]) := case
        (client_toggles[0] != last_client_toggle[0]) : client_toggles[0];
        TRUE : last_client_toggle[0];
    esac;

    next(last_client_toggle[1]) := case
        (client_toggles[1] != last_client_toggle[1]) : client_toggles[1];
        TRUE : last_client_toggle[1];
    esac;

    next(last_client_toggle[2]) := case
        (client_toggles[2] != last_client_toggle[2]) : client_toggles[2];
        TRUE : last_client_toggle[2];
    esac;

    next(last_server_toggle) := case
        (server_toggle != last_server_toggle) : server_toggle;
        TRUE : last_server_toggle;
    esac;

DEFINE
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);




MODULE ClientExtended(queue, client_id)
VAR
    fault_mode : {none, stuck_sending, stuck_sent};
    client_state : {sending, sent};
    request_toggle : boolean;    
    requests_sent : 0..100;       

ASSIGN
    init(fault_mode) := none;

    init(client_state) := sending;
    init(request_toggle) := FALSE;
    init(requests_sent) := 0;

    next(fault_mode) :=
        case
            fault_mode = none : {none, stuck_sending, stuck_sent};
            TRUE              : fault_mode;
        esac;

    next(client_state) :=
        case
        fault_mode = stuck_sending : sending;
        fault_mode = stuck_sent : sent;

            client_state = sending & queue.full : sending;
            client_state = sending & !queue.full : sent;
            client_state = sent & !queue.full & request_toggle = queue.last_client_toggle[client_id] : sending;
            client_state = sent & queue.full : sent;
            TRUE : client_state;
        esac;
 
    -- Toggle the bit each time we make a new request
    next(request_toggle) := case
        fault_mode = none &
        client_state = sending & !queue.full : !request_toggle;                     -- toggle!
        TRUE : request_toggle;                                                      -- keep same value otherwise
    
    next(requests_sent) := case
        client_state = sending & !queue.full & requests_sent < 100 : requests_sent + 1;                   
        TRUE : requests_sent;                                                    
    esac;

    esac;


-- =========================================================
-- Server module
-- =========================================================


MODULE Extended()
DEFINE
    Q_SIZE := 4;
VAR
    client_toggles : array 0..2 of boolean;

    client1 : ClientExtended(queue, 0);

    client2 : ClientExtended(queue, 1);

    client3 : ClientExtended(queue, 2);
    server : Server(queue);
    queue : QueueExtended(Q_SIZE, client_toggles, server.request_toggle);

ASSIGN
    client_toggles[0] := client1.request_toggle;
    client_toggles[1] := client2.request_toggle;
    client_toggles[2] := client3.request_toggle;


-- =========================================================
--  Synchronization Module
-- =========================================================
MODULE Sync()
VAR
    nominal  : Nominal();
    extended : Extended();

-- Whenever nominal server consumes, eventually an extended server consumes

LTLSPEC G (
    nominal.server.request_received =
    extended.server1.request_received +
    extended.server2.request_received
)


-- =========================================================
--  Main Module
-- =========================================================
MODULE main
VAR
    sync : Sync();
