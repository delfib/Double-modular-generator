-- =========================================================
-- Queue module
-- =========================================================

MODULE Queue(Q_SIZE, client_toggle, server_toggle)
VAR
    head : 0..3;
    tail : 0..3;
    last_client_toggle : boolean;  -- last toggle value we saw
    last_server_toggle : boolean;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
    init(last_client_toggle) := FALSE;
    init(last_server_toggle) := FALSE;

    next(tail) := case
        (client_toggle != last_client_toggle) : (tail + 1) mod Q_SIZE;    -- produce if toggle changed (new request detected)
        TRUE : tail;
    esac;

    next(head) := case
        (server_toggle != last_server_toggle) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

    next(last_client_toggle) := case
        (client_toggle != last_client_toggle) : client_toggle;
        TRUE : last_client_toggle;
    esac;

    next(last_server_toggle) := case
        (server_toggle != last_server_toggle) : server_toggle;
        TRUE : last_server_toggle;
    esac;


DEFINE
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);



-- =========================================================
-- Client module
-- =========================================================
MODULE Client(queue)
VAR
    client_state : {sending, sent};
    request_toggle : boolean;  
    num_requests_sent : 0..100;         

ASSIGN
    init(client_state) := sending;
    init(request_toggle) := FALSE;
    init(num_requests_sent) := 0;

    next(client_state) :=
        case
            client_state = sending & queue.full : sending;
            client_state = sending & !queue.full : sent;
            client_state = sent & !queue.full : sending;
            client_state = sent & queue.full : sent;
            TRUE : client_state;
        esac;
 
    next(request_toggle) := case
        client_state = sending & !queue.full : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

     next(num_requests_sent) := case
        client_state = sending & !queue.full & num_requests_sent < 100 : num_requests_sent + 1;                   
        TRUE : num_requests_sent;                                                    
    esac;


-- =========================================================
-- Server module
-- =========================================================
MODULE Server(queue)
VAR
    server_state : {receiving, received};
    request_toggle : boolean;  
    num_requests_received : 0..100;
ASSIGN
    init(server_state) := receiving;
    init(request_toggle) := FALSE;
    init(num_requests_received) := 0;

    next(server_state) :=
        case
            server_state = receiving & queue.empty : receiving;
            server_state = receiving & !queue.empty : received;
            server_state = received & !queue.empty : receiving;
            server_state = received & queue.empty : received;
            TRUE : server_state;
        esac;

    next(request_toggle) := case
        server_state = receiving & !queue.empty : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(num_requests_received) := case
        server_state = receiving & !queue.empty & num_requests_received < 100 : num_requests_received + 1;                   
        TRUE : num_requests_received;                                                    
    esac;


-- =========================================================
-- Nominal wrapper
-- =========================================================
MODULE Nominal()
DEFINE
    Q_SIZE := 4;
VAR
    client : Client(queue);
    server : Server(queue);
    queue : Queue(Q_SIZE, client.request_toggle, server.request_toggle);

MODULE QueueExtended(Q_SIZE, client_toggle, server_toggles)
VAR
    head : 0..3;
    tail : 0..3;
    last_client_toggle : boolean;  -- last toggle value we saw
    last_server_toggle : array 0..2 of boolean;
    next_server_turn   : 0..2;  

ASSIGN
    init(head) := 0;
    init(tail) := 0;
    init(last_client_toggle) := FALSE;
        init(last_server_toggle[0]) := FALSE;
    init(last_server_toggle[1]) := FALSE;
    init(last_server_toggle[2]) := FALSE;
    init(next_server_turn) := {0,1,2};

    next(tail) := case
        (client_toggle != last_client_toggle) : (tail + 1) mod Q_SIZE;    -- produce if toggle changed (new request detected)
        TRUE : tail;
    esac;

    next(head) := case
        (server_toggles[0] != last_server_toggle[0]) : (head + 1) mod Q_SIZE;
        (server_toggles[1] != last_server_toggle[1]) : (head + 1) mod Q_SIZE;
        (server_toggles[2] != last_server_toggle[2]) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

    next(last_client_toggle) := case
        (client_toggle != last_client_toggle) : client_toggle;
        TRUE : last_client_toggle;
    esac;

        next(last_server_toggle[0]) := case
        (server_toggles[0] != last_server_toggle[0]) : server_toggles[0];
        TRUE : last_server_toggle[0];
    esac;

    next(last_server_toggle[1]) := case
        (server_toggles[1] != last_server_toggle[1]) : server_toggles[1];
        TRUE : last_server_toggle[1];
    esac;

    next(last_server_toggle[2]) := case
        (server_toggles[2] != last_server_toggle[2]) : server_toggles[2];
        TRUE : last_server_toggle[2];
    esac;

    next(next_server_turn) := case
        next_server_turn = 0 : 1;
        next_server_turn = 1 : 2;
        next_server_turn = 2 : 0;
        TRUE : next_server_turn;
    esac;

DEFINE
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);



MODULE ServerExtended(queue, server_id)
VAR
    fault_mode : {none, stuck_receiving, stuck_received};
    server_state : {receiving, received};
    request_toggle : boolean;  
    num_requests_received : 0..100;
ASSIGN
    init(fault_mode) := none;

    init(server_state) := receiving;
    init(request_toggle) := FALSE;
    init(num_requests_received) := 0;

    next(fault_mode) :=
        case
            fault_mode = none : {none, stuck_receiving, stuck_received};
            TRUE              : fault_mode;
        esac;

    next(server_state) :=
        case
        fault_mode = stuck_receiving : receiving;
        fault_mode = stuck_received : received;

            server_state = receiving & queue.empty : receiving;
            server_state = receiving & !queue.empty & queue.next_server_turn = server_id : received;
            server_state = received & !queue.empty : receiving;
            server_state = received & queue.empty : received;
            TRUE : server_state;
        esac;

    next(request_toggle) := case
        server_state = receiving & !queue.empty & queue.next_server_turn = server_id : !request_toggle;
        TRUE : request_toggle;                                                    
    
    esac;

    next(num_requests_received) := case
        server_state = receiving & !queue.empty & queue.next_server_turn = server_id & num_requests_received < 100 : num_requests_received + 1;
        TRUE : num_requests_received;                                                    
    esac;



-- =========================================================
-- Nominal wrapper
-- =========================================================


MODULE Extended()
DEFINE
    Q_SIZE := 4;
VAR
    client : Client(queue);
    server_toggles : array 0..2 of boolean;

    server1 : ServerExtended(queue, 0);

    server2 : ServerExtended(queue, 1);

    server3 : ServerExtended(queue, 2);
    queue : QueueExtended(Q_SIZE, client.request_toggle, server_toggles);

ASSIGN
    server_toggles[0] := server1.request_toggle;
    server_toggles[1] := server2.request_toggle;
    server_toggles[2] := server3.request_toggle;


-- =========================================================
--  Synchronization Module
-- =========================================================
MODULE Sync()
VAR
    nominal  : Nominal();
    extended : Extended();


LTLSPEC G (
    nominal.server.num_requests_received =
    extended.server1.num_requests_received +
    extended.server2.num_requests_received + 
    extended.server3.num_requests_received
)


-- =========================================================
--  Main Module
-- =========================================================
MODULE main
VAR
    sync : Sync();
