<?xml version="1.0" encoding="UTF-8"?>
<fault-injection>

    <model>R_Protocol.smv</model>

    <protocol-type>R</protocol-type>

    <target-module>Client</target-module>

    <redundancy count="3"/>

    <faults>
        <!--
        <fault id="stuck_receiving">
            <type>stuck-at</type>
            <variable>server_state</variable>
            <value>receiving</value>
        </fault>

        <fault id="stuck_received">
            <type>stuck-at</type>
            <variable>server_state</variable>
            <value>received</value>
        </fault>

        -->
        <fault id="stuck_sending">
            <type>stuck-at</type>
            <variable>client_state</variable>
            <value>sending</value>
        </fault>

        <fault id="stuck_sent">
            <type>stuck-at</type>
            <variable>client_state</variable>
            <value>sent</value>
        </fault>
        <!--
        <fault id="byzantine_state">
            <type>byzantine</type>
            <variable>client_request_state</variable>
        </fault>
        -->
    </faults>

    <properties>
        <property id="nominal_implies_extended">
            <comment></comment>
            <spec>
                nominal.client.num_requests_sent =
                extended.client1.num_requests_sent +
                extended.client2.num_requests_sent + 
                extended.client3.num_requests_sent 
            </spec>
            <!--
            -->
            <!--
            <spec>
                (nominal.server.server_request_state = received -> AF (extended.server1.server_request_state = received | extended.server2.server_request_state = received))
            </spec>
            -->
        </property>
    </properties>

</fault-injection>